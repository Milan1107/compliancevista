# The URL where your backend/contact.php file is hosted
# Set this in your Vercel Environment Variables in production
VITE_CONTACT_API_URL=https://yourdomain.com/backend/contact.php

# Google reCAPTCHA v3 Configuration
# Get these from: https://www.google.com/recaptcha/admin
# IMPORTANT: Site Key is PUBLIC (can be exposed), Secret Key is PRIVATE (keep secure)
VITE_RECAPTCHA_SITE_KEY=6LdpZq4sAAAAACc87ym0oRUjKpiJ5nIsi_LWPxTh
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here
